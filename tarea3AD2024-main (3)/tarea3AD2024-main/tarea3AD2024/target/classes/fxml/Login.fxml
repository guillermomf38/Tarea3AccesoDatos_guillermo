<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="350.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.LoginController">
   <top>
      <HBox alignment="TOP_CENTER" prefHeight="54.0" prefWidth="500.0" style="-fx-background-color: #E57373;" BorderPane.alignment="CENTER">
         <children>
            <Label text="CIRCO">
               <font>
                  <Font name="Britannic Bold" size="32.0" />
               </font>
               <HBox.margin>
                  <Insets top="10.0" />
               </HBox.margin>
            </Label>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </HBox>
   </top>
   <left>
      <VBox alignment="CENTER" prefHeight="273.0" prefWidth="262.0" spacing="10.0" style="-fx-background-color: lightskyblue;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="18.0" prefWidth="216.0" text="Espectáculos disponibles">
               <font>
                  <Font name="Britannic Bold" size="14.0" />
               </font>
            </Label>
            <ListView fx:id="lvEspectaculos" prefHeight="214.0" prefWidth="246.0">
               <VBox.margin>
                  <Insets left="5.0" />
               </VBox.margin>
            </ListView>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </VBox>
   </left>
   <right>
      <VBox alignment="CENTER" prefHeight="296.0" prefWidth="238.0" spacing="46.0" style="-fx-background-color: lightskyblue;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Inicio de Sesión">
               <font>
                  <Font name="Britannic Bold" size="18.0" />
               </font>
            </Label>
            <TextField fx:id="txtUsuario" promptText="Usuario">
               <font>
                  <Font name="Arial" size="13.0" />
               </font>
               <VBox.margin>
                  <Insets left="20.0" right="20.0" />
               </VBox.margin>
            </TextField>
            <PasswordField fx:id="psPassword" promptText="Contraseña">
               <font>
                  <Font name="Arial" size="13.0" />
               </font>
               <VBox.margin>
                  <Insets left="20.0" right="20.0" />
               </VBox.margin>
            </PasswordField>
            <HBox prefHeight="26.0" prefWidth="208.0" spacing="25.0">
               <children>
                  <Button fx:id="btnReiniciar" mnemonicParsing="false" onAction="#reiniciar" prefHeight="26.0" prefWidth="100.0" style="-fx-background-color: #E57373; -fx-text-fill: white;" text="Reiniciar" />
                  <Button fx:id="btnInicioSesion" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="26.0" prefWidth="106.0" style="-fx-background-color: white;" text="Iniciar Sesión">
                     <font>
                        <Font name="Arial" size="12.0" />
                     </font>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets left="20.0" right="20.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </right>
</BorderPane>
